# Copy this file to `keystore.properties` in the repo root and fill in
# values for your own release keystore. The real `keystore.properties`
# file is gitignored — never commit it.
#
# Generate a keystore (once, store it OUTSIDE the repo):
#
#   keytool -genkey -v \
#     -keystore /path/outside/repo/popmobile-release.keystore \
#     -alias popmobile -keyalg RSA -keysize 2048 -validity 10000
#
# Back that keystore up securely. Losing it means you can never publish
# an upgrade to an app installed with the same signature.

storeFile=/absolute/path/outside/repo/popmobile-release.keystore
storePassword=CHANGE_ME
keyAlias=popmobile
keyPassword=CHANGE_ME
