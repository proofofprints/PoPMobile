<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_framing_rect_width="280dp"
        app:zxing_framing_rect_height="280dp"
        app:zxing_viewfinder_mask="#80000000"
        app:zxing_viewfinder_laser="#49EACB"
        app:zxing_viewfinder_laser_visibility="true"
        app:zxing_use_texture_view="true"
        app:zxing_preview_scaling_strategy="fitCenter" />

    <!-- Overlay: prompt at top, instructions at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#B3000000">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan Kaspa Wallet QR"
            android:textColor="#49EACB"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Align the QR code inside the box below"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingTop="8dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:padding="24dp"
        android:background="#B3000000"
        android:text="Hold steady — scanning…"
        android:textColor="#49EACB"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:gravity="center" />

</FrameLayout>
